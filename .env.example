# LLM (required)
ANTHROPIC_API_KEY=sk-ant-...

# News sources (optional — adaptéry se bez klíče přeskočí)
NEWSAPI_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
FOREXFACTORY_USER_AGENT=Tradezer/1.0

# DB
# Local:
DATABASE_URL=sqlite+aiosqlite:///./local.db
# Vercel / Neon / Supabase:
# DATABASE_URL=postgresql://user:password@host/dbname

# App
APP_ENV=development          # development | production
INTERNAL_API_TOKEN=change-me-in-production
REFRESH_INTERVAL_MINUTES=5   # ignorováno na Vercel (použij Vercel Cron Jobs)

# CORS — vlastní doména (volitelné, *.vercel.app je povoleno automaticky)
# ALLOWED_ORIGIN=https://tradezer.example.com

# Calibration thresholds
NEUTRAL_THRESHOLD_EURUSD=0.002
NEUTRAL_THRESHOLD_DEFAULT=0.002

# DB pool (jen pro PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# === VERCEL FRONTEND (web/) ===
# Nastav v Vercel dashboard pro web projekt:
# NEXT_PUBLIC_API_URL=https://tradezer-api.vercel.app
